# Vercel deploy bundle: keep ONLY what the Python function (api/index.py)
# actually needs at runtime. Without this file the entire repo (incl.
# 545MB of frontend/.next/node_modules) gets uploaded, blowing the 500MB
# Lambda ephemeral storage limit.

# Frontend is deployed as a SEPARATE Vercel project (frontend-delta-three-81)
frontend/

# Git worktrees with feature branches; not needed for prod
.worktrees/

# Tests + dev infra
tests/
.pytest_cache/

# Local Python venv (if any)
venv/
.venv/
__pycache__/
*.pyc

# Docs + planning
docs/
plans/
*.md

# Build/dev artifacts
node_modules/
.next/
*.docx
*.pdf
*.html
*.png

# Logs / status
logs/
status.json

# Local sqlite cache (not used in serverless; uses Neon postgres instead)
alpha_agent/data/factor_db.sqlite

# NOTE: parquets MUST be bundled — the factor signal's _load_panel()
# reads alpha_agent/data/factor_universe_sp500_v3.parquet (~10MB) at
# request time. Without it every cron run fails with FileNotFoundError.
# Total parquet weight ~13MB, harmless for 500MB Lambda budget.

# AlphaCore blueprints (large docs)
_tmp_AlphaCore_*
AlphaCore_*

# OS / IDE
.DS_Store
.vscode/
.idea/

# CI / superpowers session caches
.superpowers/
