{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "regions": ["hkg1"],
  "functions": {
    "api/index.py": {
      "includeFiles": "alpha_agent/data/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/qcore", "destination": "/api/index" }
  ]
}
