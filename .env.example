# LLM Provider: "ollama" | "openai" | "kimi"
LLM_PROVIDER=kimi

# Kimi For Coding (Anthropic-compat, UA-gated)
# Get key from Kimi CLI / Claude Code onboarding. Key prefix: sk-kimi-*
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_MODEL=kimi-for-coding

# Startup health check — abort boot if selected provider is unreachable
LLM_STARTUP_HEALTHCHECK=true

# Ollama (local or AutoDL via SSH tunnel)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4-26b

# Generic OpenAI-compatible (fallback)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
